FLEETWARDEN_DATABASE_URL=sqlite:////absolute/path/to/fleetwarden.db
FLEETWARDEN_SSH_CONFIG_PATH=/Users/yourname/.ssh/config
FLEETWARDEN_SSH_COMMAND_TIMEOUT_SECONDS=60
FLEETWARDEN_WORKER_POLL_INTERVAL_SECONDS=1
FLEETWARDEN_REMOTE_AGENT_COMMAND=codex exec --json

# LiteLLM-backed generation for TaskSpec and per-node proposals.
FLEETWARDEN_LLM_TASKSPEC_MODEL=openai/gpt-4o-mini
FLEETWARDEN_LLM_PROPOSAL_MODEL=openai/gpt-4o-mini

# Optional FleetWarden-scoped overrides passed directly to LiteLLM.
# Provider-native env vars such as OPENAI_API_KEY or ANTHROPIC_API_KEY also work.
FLEETWARDEN_LLM_API_BASE=
FLEETWARDEN_LLM_API_KEY=
